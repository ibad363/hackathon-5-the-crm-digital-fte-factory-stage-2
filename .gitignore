*.py[cod]
*$py.class
*.so

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Packages and Builds
*.egg
*.egg-info/
dist/
build/
*.whl

# Type checking & Testing
.mypy_cache/
.pytest_cache/
.tox/
.coverage
htmlcov/
coverage.xml


# ==============================================================================
# 2. NODE.JS / NEXT.JS (Web Form / Frontend)
# ==============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js build output
.next/
out/
build/

# Next.js environment files (keep .env.example committed though)
.env*.local
.env.development.local
.env.test.local
.env.production.local


# ==============================================================================
# 3. DATABASE & KAFKA LOGS
# ==============================================================================
*.sqlite
*.sqlite3
*.db
*.db-journal

