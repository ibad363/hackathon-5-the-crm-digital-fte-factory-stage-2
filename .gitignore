# IntelliJ / PyCharm / WebStorm
.idea/
*.iml


# ==============================================================================
# 5. SECRETS & CONFIGURATION
# ==============================================================================
# NEVER commit API keys, passwords, or credentials!
secrets/
*.pem
*.key
*.cert
*.crt
# (If you create a local .env for OpenAI, Twilio, Gmail API credentials)
.env
.env.local
.env.development
.env.test
.env.production

