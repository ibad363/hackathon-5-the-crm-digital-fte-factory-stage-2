# TaskVault CRM - Environment Variables

# ===========================================
# LLM Configuration (OpenRouter)
# ===========================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ===========================================
# Database (PostgreSQL with pgvector)
# ===========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/crm_db

# ===========================================
# Kafka (Event Streaming)
# ===========================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===========================================
# Gmail Integration (Push via Pub/Sub)
# ===========================================
# GCP Project ID for Pub/Sub
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# OAuth credentials are stored in: credentials/gmail_credentials.json
# Token is auto-generated at: credentials/token.json

# ===========================================
# Twilio (WhatsApp Integration)
# ===========================================
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ===========================================
# API Security
# ===========================================
SUPPORT_FORM_API_KEY=your_internal_api_key
